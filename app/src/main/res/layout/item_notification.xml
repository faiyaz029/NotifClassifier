<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="6dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row 1: App label + Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAppLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="App Name"
                android:textSize="11sp"
                android:textColor="#888888"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="11sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Row 2: Sender name -->
        <TextView
            android:id="@+id/tvSender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sender"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="4dp" />

        <!-- Row 3: Message body (max 2 lines) -->
        <TextView
            android:id="@+id/tvBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message body"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp" />

        <!-- Row 4: Decision badge + confidence -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDecisionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Classifying…"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/badge_bg" />

            <TextView
                android:id="@+id/tvConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_marginStart="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Row 5: Star rating row (shown after decision) -->
        <LinearLayout
            android:id="@+id/ratingBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rate:"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/star1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="22sp"
                android:textColor="#666666"
                android:gravity="center" />

            <TextView
                android:id="@+id/star2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="22sp"
                android:textColor="#666666"
                android:gravity="center" />

            <TextView
                android:id="@+id/star3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="22sp"
                android:textColor="#666666"
                android:gravity="center" />

            <TextView
                android:id="@+id/star4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="22sp"
                android:textColor="#666666"
                android:gravity="center" />

            <TextView
                android:id="@+id/star5"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="22sp"
                android:textColor="#666666"
                android:gravity="center" />
        </LinearLayout>

        <!-- Feedback status (submitted / error / submitting) -->
        <TextView
            android:id="@+id/tvFeedbackStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
